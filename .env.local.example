# Copy to .env.local and fill in. .env.local is gitignored, never commit real keys.

# Required: evidence search
TAVILY_API_KEY=tvly-xxxxxxxx

# Set ONE of these. Priority order: OpenAI, then Gemini, then Anthropic, to
# keep the app's runtime calls off the Claude Code subscription quota used to
# build it. OpenAI and Gemini keys come from Hack-Nation partner credits.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: voice for the Socratic interview (ElevenLabs text-to-speech).
# Without it the interview runs as text; the voice toggle reports unavailable.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional: raises GitHub API rate limits for the scanners and targeted sourcing
GITHUB_TOKEN=
